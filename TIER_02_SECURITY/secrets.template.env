# JartOS Secrets Template (1Password Mapping)
# Use this file with 'op run' to inject secrets into the environment.
# Example: op run --env-file=TIER_02_SECURITY/secrets.template.env -- ./your_script.py

# LLM APIs
ANTHROPIC_API_KEY="op://Personal/Anthropic/api-key"
OPENAI_API_KEY="op://Personal/OpenAI/api-key"
MINIMAX_API_KEY="op://Personal/MiniMax/api-key"
MISTRAL_API_KEY="op://Personal/Mistral/api-key"

# Communications
TELEGRAM_BOT_TOKEN="op://Personal/Telegram-JartOS/token"
ZADARMA_USER_KEY="op://Personal/Zadarma/user-key"
ZADARMA_SECRET="op://Personal/Zadarma/secret"

# LiveKit
LIVEKIT_API_KEY="op://Personal/LiveKit/api-key"
LIVEKIT_API_SECRET="op://Personal/LiveKit/api-secret"
LIVEKIT_URL="op://Personal/LiveKit/url"

# Infrastructure
HOME_ASSISTANT_TOKEN="op://Personal/HomeAssistant/long-lived-token"
GUARDIAN_SECRET_KEY="op://Personal/JartOS-Guardian/secret-key"
LITELLM_MASTER_KEY="op://Personal/LiteLLM/master-key"
