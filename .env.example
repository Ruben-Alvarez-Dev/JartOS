# ==============================================
# OPOSICIONES-SYSTEM Configuration
# ==============================================
# Copy this file to .env and fill in your values

# ---------------------------------------------
# LLM APIs
# ---------------------------------------------
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MISTRAL_API_KEY=your_mistral_api_key_here

# ---------------------------------------------
# Telegram Bot
# ---------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ---------------------------------------------
# Local LLM (Fallback)
# ---------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ---------------------------------------------
# Data Paths
# ---------------------------------------------
DATA_DIR=~/.oposiciones-system/data
VECTOR_DB_PATH=~/.oposiciones-system/vectors.db
MEMORY_DB_PATH=~/.oposiciones-system/memory.db

# ---------------------------------------------
# Flashcards (SM-2 Algorithm)
# ---------------------------------------------
FLASHCARD_DB_PATH=~/.oposiciones-system/flashcards.db

# ---------------------------------------------
# Redis (Optional, for caching)
# ---------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------
# Security
# ---------------------------------------------
API_SECRET_KEY=generate_a_secure_random_key_here
